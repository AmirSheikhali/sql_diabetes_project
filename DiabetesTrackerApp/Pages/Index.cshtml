@page
@model IndexModel

<link rel="stylesheet" href="~/css/site.css" />

<div class="main-container">

    <div class="left-panel">

        <div class="header card">
            <h2>Diabetes Tracker</h2>
            <a href="/AddEntry" class="btn">Add Entry</a>
        </div>

        <div class="card demo-user">
            <strong>Demo User:</strong> @Model.UserName
        </div>

        <div class="card user-selector">
            <a class="btn @(Model.SelectedUser == 1 ? "active" : "")" href="/?userId=1">Amir</a>
            <a class="btn @(Model.SelectedUser == 2 ? "active" : "")" href="/?userId=2">David</a>
            <a class="btn @(Model.SelectedUser == 3 ? "active" : "")" href="/?userId=3">Jimmy</a>
        </div>

        <h1 class="title">Dashboard Overview</h1>

        <!-- SUMMARY -->
        <div class="card">
            <p>Avg BG: @Model.AvgBG mg/dL</p>
            <p>Avg Insulin: @Model.AvgInsulin units</p>
        </div>

        <!-- BG CHART -->
        <div class="card">
            <h3>Blood Glucose Trend</h3>
            <canvas id="bgChart"></canvas>
        </div>

        <!-- INSULIN CHART -->
        <div class="card">
            <h3>Insulin Trend</h3>
            <canvas id="insulinChart"></canvas>
        </div>

        <!-- TABLE -->
        <div class="card">
            <h3>Recent Entries</h3>

            <table>
                <tr>
                    <th>Time</th>
                    <th>BG</th>
                    <th>Insulin</th>
                    <th>Note</th>
                </tr>

                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td>@entry.Date</td>
                        <td>@entry.BG</td>
                        <td>@entry.Insulin</td>
                        <td>@entry.Note</td>
                    </tr>
                }
            </table>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Labels));
    const bgData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BGValues));
    const insulinData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.InsulinValues));

    new Chart(document.getElementById('bgChart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Blood Glucose',
                data: bgData,
                borderWidth: 2
            }]
        }
    });

    new Chart(document.getElementById('insulinChart'), {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Insulin',
                data: insulinData,
                borderWidth: 2
            }]
        }
    });
</script>